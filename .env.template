# Copy this file to `.env` (which is git-ignored) and source it before
# running release.sh:
#
#     cp .env.template .env
#     source .env
#     ./mac/LivingRoomTV/scripts/release.sh
#
# Find your values with:
#   security find-identity -v -p codesigning   # → Team ID + cert common name
#   xcrun notarytool history --keychain-profile <name>  # → verify profile

# Your 10-character Apple Team ID.
export APPLE_TEAM_ID="ABCD1234EF"

# Full common name of your Developer ID Application cert, exactly as it
# appears in `security find-identity -v -p codesigning`.
export DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (ABCD1234EF)"

# Keychain profile name used by `xcrun notarytool`. Must match the name
# you passed to `xcrun notarytool store-credentials <name>` (see README).
export NOTARY_PROFILE="AC_PASSWORD"
